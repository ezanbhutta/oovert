{
  "name": "oovert",
  "version": "1.0.0",
  "private": true,
  "description": "OOVERT — brand strategy and identity studio. Static site rendered by Eleventy from editable content files.",
  "scripts": {
    "build": "eleventy",
    "dev": "eleventy --serve",
    "seo": "node tools/seo-crawler/crawl.js",
    "seo:audit": "eleventy && node tools/seo-crawler/crawl.js --dir _site"
  },
  "dependencies": {
    "@11ty/eleventy": "3.1.6",
    "@11ty/eleventy-img": "^6.0.4"
  }
}
