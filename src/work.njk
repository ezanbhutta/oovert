---
permalink: "/work/index.html"
---
{%- set currentPath = "/work/" -%}
<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
  <meta charset="UTF-8">
  {% include "analytics.njk" %}
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Work — OOVERT</title>
  <meta name="description" content="Selected work from OOVERT — brand strategy, naming and identity, built end to end by senior hands. See how we present a project, and ask for the work closest to your category.">
  <link rel="canonical" href="https://oovert.com/work/">
  <meta name="theme-color" content="#F3F0E9">

  <meta property="og:type" content="website">
  <meta property="og:site_name" content="OOVERT">
  <meta property="og:title" content="Work — OOVERT">
  <meta property="og:description" content="Selected brand strategy, naming and identity work, built end to end by senior hands.">
  <meta property="og:url" content="https://oovert.com/work/">
  <meta property="og:image" content="https://oovert.com/assets/og.png">
  <meta name="twitter:card" content="summary_large_image">

  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <script>document.documentElement.classList.replace('no-js', 'js');</script>

  <link rel="preload" href="/assets/fonts/archivo-var.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/instrument-serif-italic.woff2" as="font" type="font/woff2" crossorigin>

  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/sections.css">
  <link rel="stylesheet" href="/css/work.css">

  <link rel="modulepreload" href="/js/modules/reveal.js">
  <link rel="modulepreload" href="/js/modules/nav.js">
  {% set schemaKey = "work" %}{% include "schema.njk" %}
</head>
<body class="page-work">
  <a class="skip-link" href="#main">{{ site.a11y.skipLink }}</a>

  {% include "site-header.njk" %}

  <main id="main" class="work">
    {%- set published = projectList | where('status', 'published') -%}
    {%- if published.length -%}
    {%- set feature = published[0] -%}
    {%- set fvid = feature.sections.hero.video -%}
    {%- set fimg = feature.sections.hero.image or feature.intro.image -%}
    <a class="work-feature" id="top" href="/work/{{ feature.slug | slugify }}/">
      <figure class="work-feature__media">
        {% if fvid and fvid.src %}<video class="work-feature__el" data-cs-video muted loop playsinline preload="none"{% if fvid.poster %} poster="{{ fvid.poster }}"{% endif %}{% if fvid.speed %} data-rate="{{ fvid.speed }}"{% endif %}{% if fvid.start %} data-start="{{ fvid.start }}"{% endif %}{% if fvid.end %} data-end="{{ fvid.end }}"{% endif %}><source src="{{ fvid.src }}"></video>
        {% elif fimg %}<img class="work-feature__el" src="{{ fimg }}" alt="{{ feature.sections.hero.alt or feature.name }}" fetchpriority="high">
        {% else %}<span class="work-feature__ph" aria-hidden="true">{{ feature.name }}</span>{% endif %}
        <span class="work-feature__scrim" aria-hidden="true"></span>
      </figure>
      <div class="work-feature__body">
        <h1 class="work-feature__eyebrow">Selected work</h1>
        <p class="work-feature__name">{{ feature.name }}<span class="work-feature__go" aria-hidden="true">&rarr;</span></p>
        <p class="work-feature__line">{{ feature.intro.headline or feature.statement }}</p>
        <dl class="work-feature__meta">
          <div><dt>Client</dt><dd>{{ feature.client or feature.name }}</dd></div>
          <div><dt>Scope</dt><dd>{{ feature.scope }}</dd></div>
          <div><dt>Year</dt><dd>{{ feature.year }}</dd></div>
        </dl>
      </div>
    </a>

    {% if published.length > 1 %}
    <div class="work-reel">
      {% for p in published %}{% if not loop.first %}
      {%- set img = p.sections.hero.image or p.intro.image -%}
      {%- set plateAccent = (p.theme.accent | onLight) if (p.theme and p.theme.accent) else '#6039CE' -%}
      <a class="work-plate" href="/work/{{ p.slug | slugify }}/" data-reveal style="--plate-accent: {{ plateAccent }}">
        <figure class="work-plate__media">
          {% if img %}<img src="{{ img }}" alt="{{ p.sections.hero.alt or p.name }}" loading="lazy">
          {% else %}<span class="work-plate__ph" aria-hidden="true">{{ p.name }}</span>{% endif %}
          <span class="work-plate__index" aria-hidden="true">0{{ loop.index }}</span>
        </figure>
        <div class="work-plate__foot">
          <div class="work-plate__id">
            <h2 class="work-plate__name">{{ p.name }}<span class="work-plate__go" aria-hidden="true">&rarr;</span></h2>
            <p class="work-plate__line">{{ p.intro.headline or p.statement }}</p>
          </div>
          <dl class="work-plate__meta">
            <div><dt>Client</dt><dd>{{ p.client or p.name }}</dd></div>
            <div><dt>Scope</dt><dd>{{ p.scope }}</dd></div>
            <div><dt>Year</dt><dd>{{ p.year }}</dd></div>
          </dl>
        </div>
      </a>
      {% endif %}{% endfor %}
    </div>
    {% endif %}
    {%- else -%}
    <header class="work-hero" id="top">
      <p class="work-hero__eyebrow">The evidence</p>
      <h1 class="work-hero__title">Selected <em>work.</em></h1>
    </header>
    {%- endif -%}

    <section class="work-more">
      <p class="work-more__line" data-reveal-lines>
        <span class="line"><span class="line__inner">More, <em>on request.</em></span></span>
      </p>
      <p class="work-more__note" data-reveal>
        We are still adding to this page. Tell us the category you play in and we will show you the closest thing we have done, with clients you can call.
      </p>
      <a class="work-more__cta" href="/#contact" data-reveal>Start a project <span aria-hidden="true">&rarr;</span></a>
    </section>
  </main>

  {% include "site-footer.njk" %}

  <script type="module" src="/js/work.js"></script>
</body>
</html>
