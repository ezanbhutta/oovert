---
permalink: "/404.html"
eleventyExcludeFromCollections: true
---
<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Perfectly camouflaged — OOVERT</title>
  <meta name="description" content="This page blended in so well that no one can find it anymore.">
  <meta name="robots" content="noindex">
  <meta name="theme-color" content="#F3F0E9">

  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <script>document.documentElement.classList.replace('no-js', 'js');</script>

  <link rel="preload" href="/assets/fonts/archivo-var.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/instrument-serif-italic.woff2" as="font" type="font/woff2" crossorigin>

  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/components.css">

  <style>
    /* The one page that took our advice's inverse: it blended in, and
       disappeared. The mark itself is camouflaged — outline-faint on paper. */
    .lost {
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 100svh;
      padding: var(--space-8) var(--margin);
    }
    .lost__label {
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: var(--track-label);
      text-transform: uppercase;
      color: var(--ink-soft);
    }
    .lost__title {
      margin-top: var(--space-4);
      font-size: var(--text-2xl);
      font-weight: 640;
      line-height: 0.92;
      letter-spacing: -0.028em;
      text-transform: uppercase;
      font-variation-settings: 'wdth' 112;
      max-width: 8em;
    }
    .lost__title em {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 400;
      text-transform: none;
      letter-spacing: -0.01em;
      color: var(--accent-deep);
    }
    .lost__note {
      margin-top: var(--space-5);
      max-width: 34em;
      font-size: var(--text-lede);
      line-height: 1.5;
      color: var(--ink-soft);
      text-wrap: pretty;
    }
    .lost__ctas {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--space-4);
      margin-top: var(--space-6);
    }
    .lost__mark {
      position: fixed;
      right: calc(-1 * var(--margin));
      bottom: -6vh;
      width: min(52vw, 40rem);
      opacity: 0.08;
      pointer-events: none;
    }
    .lost__mark svg { width: 100%; height: auto; }
  </style>
</head>
<body>
  <main class="lost" id="main">
    <p class="lost__label">404 — Perfectly camouflaged</p>
    <h1 class="lost__title">This page <em>blended in.</em></h1>
    <p class="lost__note">
      So well that no one can find it anymore. That is the thing about
      camouflage: it works. Pages, brands, whole companies. What blends in,
      disappears.
    </p>
    <div class="lost__ctas">
      <a class="btn" href="/"><span class="btn__label">Back to visibility</span><span class="btn__arrow" aria-hidden="true">&rarr;</span></a>
      <a class="link-quiet" href="/work/">Work that refuses to hide</a>
    </div>
    <div class="lost__mark" aria-hidden="true">
      {% include "mark.njk" %}
    </div>
  </main>
</body>
</html>
