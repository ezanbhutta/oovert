        <path d="M77.71,64.53c-10.39-2.55-17.39-13.26-17.3-23.78-.5-19.73,19.54-32.79,37.82-26.35,19.68,6.54,25.04,33.45,8.77,46.4-2.35,1.8-5,3.07-7.72,3.77l-.9-1.89c7.51-5.57,10.78-15.8,7.96-24.48-3.52-12.29-18.76-16.83-28.84-9.6-11.26,8.17-9.92,25.95,1.12,34.05,0,0-.9,1.89-.9,1.89h0Z"/>
