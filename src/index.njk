        <path d="M284.07,24.97v20.76c0,6.53,4,9.17,9.69,9.17,1.26,0,2.63-.11,3.79-.42v10.85c-1.79.42-4.42.63-6.32.63-11.38,0-18.96-6.95-18.96-20.02v-20.97h-9.8v-11.17h9.8V0h11.8v13.8h13.49v11.17h-13.49Z"/>
