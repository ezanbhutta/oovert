{#- siteVideo(v, cls) — a homepage <video> with its owner settings. Autoplay
    implies muted + playsinline; speed / start / end are read by the video.js
    module as data-rate / start / end. -#}
{%- macro siteVideo(v, cls='') -%}
<video class="cs-video{% if cls %} {{ cls }}{% endif %}"{% if v.poster %} poster="{{ v.poster }}"{% endif %}{% if v.controls %} controls{% endif %}{% if v.loop %} loop{% endif %}{% if v.autoplay %} autoplay muted playsinline{% elif v.muted %} muted{% endif %} preload="metadata" data-cs-video{% if v.speed %} data-rate="{{ v.speed }}"{% endif %}{% if v.start %} data-start="{{ v.start }}"{% endif %}{% if v.end %} data-end="{{ v.end }}"{% endif %}><source src="{{ v.src }}"></video>
{%- endmacro -%}
<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ site.meta.pageTitle }}</title>
  <meta name="description" content="{{ site.meta.description }}">
  <link rel="canonical" href="{{ site.meta.canonicalUrl }}">
  <meta name="theme-color" content="{{ site.meta.themeColor }}">

  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.meta.og.siteName }}">
  <meta property="og:title" content="{{ site.meta.og.title }}">
  <meta property="og:description" content="{{ site.meta.og.description }}">
  <meta property="og:url" content="{{ site.meta.og.url }}">
  <meta property="og:image" content="{{ site.meta.og.image }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{ site.meta.og.imageAlt }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ site.meta.twitter.title }}">
  <meta name="twitter:description" content="{{ site.meta.twitter.description }}">
  <meta name="twitter:image" content="{{ site.meta.twitter.image }}">

  <link rel="icon" href="favicon.svg" type="image/svg+xml">
  <link rel="icon" href="favicon.ico" sizes="32x32">
  <link rel="apple-touch-icon" href="apple-touch-icon.png">

  <script>document.documentElement.classList.replace('no-js', 'js');</script>

  <link rel="preload" href="assets/fonts/archivo-var.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="assets/fonts/instrument-serif-italic.woff2" as="font" type="font/woff2" crossorigin>

  <link rel="stylesheet" href="css/foundation.css">
  <link rel="stylesheet" href="css/components.css">
  <link rel="stylesheet" href="css/sections.css">

  <link rel="modulepreload" href="js/modules/reveal.js">
  <link rel="modulepreload" href="js/modules/nav.js">
  <link rel="modulepreload" href="js/modules/parallax.js">
  <link rel="modulepreload" href="js/modules/counters.js">
  <link rel="modulepreload" href="js/modules/smooth-scroll.js">
  <link rel="modulepreload" href="js/modules/manifesto.js">
  <link rel="modulepreload" href="js/modules/backdrop.js">
  <link rel="modulepreload" href="js/modules/herofield.js">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "additionalType": "https://schema.org/ProfessionalService",
    "name": {{ site.schema.name | dump | safe }},
    "legalName": {{ site.schema.legalName | dump | safe }},
    "url": {{ site.schema.url | dump | safe }},
    "email": {{ site.schema.email | dump | safe }},
    "foundingDate": {{ site.schema.foundingDate | dump | safe }},
    "slogan": {{ site.schema.slogan | dump | safe }},
    "description": {{ site.schema.description | dump | safe }},
    "logo": {{ site.schema.logo | dump | safe }},
    "image": {{ site.schema.image | dump | safe }},
    "areaServed": {{ site.schema.areaServed | dump | safe }},
    "knowsAbout": {{ site.schema.knowsAbout | dump | safe }},
    "makesOffer": [
{% for offer in site.schema.makesOffer %}      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": {{ offer | dump | safe }} } }{% if not loop.last %},{% endif %}
{% endfor %}    ],
    "sameAs": {{ site.schema.sameAs | dump | safe }}
  }
  </script>
</head>
<body>
  <a class="skip-link" href="#main">{{ site.a11y.skipLink }}</a>

  <header class="site-head">
    <a class="site-head__mark" href="#top" aria-label="OOVERT, back to top">
      <svg viewBox="0 0 297.55 66.38" fill="currentColor" aria-hidden="true" focusable="false">
