      </svg>
    </a>
    <nav class="site-head__nav" aria-label="Primary">
      {% for link in site.nav.links %}<a href="{{ link.href }}">{{ link.label }}</a>
      {% endfor %}</nav>
    <button class="site-head__menu" type="button" aria-expanded="false" aria-controls="menu-overlay">
      <span class="site-head__menu-label">{{ site.nav.menuButtonLabel }}</span>
    </button>
  </header>

  <div class="menu-overlay" id="menu-overlay" role="dialog" aria-modal="true" aria-label="Menu" hidden>
    <nav class="menu-overlay__nav" aria-label="Menu">
      {% for link in site.menu.links %}<a href="{{ link.href }}"><span class="menu-overlay__num">{{ link.num }}</span>{{ link.label }}</a>
      {% endfor %}</nav>
    <p class="menu-overlay__meta">{{ site.menu.meta | safe }}</p>
  </div>

  <nav class="chapter-rail" aria-label="Chapters">
    {% for item in site.chapterRail %}<a href="{{ item.href }}" aria-label="{{ item.aria }}"><span>{{ item.num }}</span></a>
    {% endfor %}</nav>

  <main id="main">

    <!-- ============ HERO ============ -->
    {%- set heroVideo = site.hero.video -%}
    <section class="hero{% if heroVideo and heroVideo.src %} hero--video{% endif %}" id="top" aria-label="Introduction">
      {% if heroVideo and heroVideo.src %}
      {{ siteVideo(heroVideo, 'hero__video') }}
      <div class="hero__scrim" aria-hidden="true"></div>
      {% else %}
      <canvas class="hero__bg" aria-hidden="true"></canvas>
      {% endif %}
      <div class="hero__meta" data-entrance style="--d:.42s">
        {% for tag in site.hero.metaTags %}<span>{{ tag }}</span>
        {% endfor %}</div>

      <h1 class="hero__title">
        {{ site.hero.title | safe }}
      </h1>

      <div class="hero__foot">
        <p class="hero__lede" data-entrance style="--d:.52s">
          {{ site.hero.lede }}
        </p>
        <div class="hero__cta" data-entrance style="--d:.62s">
          <a class="btn" href="{{ site.hero.ctaPrimary.url }}" data-magnetic>{{ site.hero.ctaPrimary.label }}<span class="btn__arrow" aria-hidden="true">&darr;</span></a>
          <a class="link-quiet" href="{{ site.hero.ctaSecondary.url }}">{{ site.hero.ctaSecondary.label }}</a>
        </div>
      </div>

      <div class="hero__strip" data-entrance style="--d:.72s">
        <span class="hero__scroll" aria-hidden="true">{{ site.hero.scrollLabel }}<i></i></span>
        <span>{{ site.hero.statusLine }}</span>
      </div>
    </section>

    <!-- ============ 01 PREMISE ============ -->
    <section class="premise" id="premise" aria-labelledby="premise-title">
      <header class="chapter-head" data-reveal-head>
        <span class="chapter-head__num" aria-hidden="true">01</span>
        <h2 class="chapter-head__label" id="premise-title">{{ site.premise.chapterLabel }}</h2>
      </header>

      <p class="premise__statement" data-reveal-lines>
        {{ site.premise.statement | safe }}
      </p>

      <div class="premise__body" data-reveal>
        <p>
          {{ site.premise.body }}
        </p>
      </div>

      <p class="premise__counter" data-reveal-lines>
        {{ site.premise.counter | safe }}
      </p>

      <div class="premise__pull" data-reveal>
        <p class="premise__pull-line">{{ site.premise.pullLine | safe }}</p>
        <p class="premise__pull-note">
          {{ site.premise.pullNote }}
        </p>
      </div>
    </section>

    <!-- ============ MANIFESTO ============ -->
    <section class="manifesto" aria-label="What we do">
      <div class="manifesto__stage">
      <canvas class="manifesto__bg" aria-hidden="true"></canvas>
      <p class="manifesto__text" data-manifesto>{{ site.manifesto.text | safe }}</p>
      </div>
    </section>

    <!-- ============ 02 PRACTICE ============ -->
    <section class="practice" id="practice" aria-labelledby="practice-title">
      <header class="chapter-head chapter-head--dark" data-reveal-head>
        <span class="chapter-head__num" aria-hidden="true">02</span>
        <h2 class="chapter-head__label" id="practice-title">{{ site.practice.chapterLabel }}</h2>
      </header>

      <p class="practice__intro" data-reveal-lines>
        {{ site.practice.intro | safe }}
      </p>

      <ol class="practice__list">
        {% for item in site.practice.items %}<li class="practice__item" data-reveal>
          <span class="practice__num" aria-hidden="true">{{ item.num }}</span>
          <h3 class="practice__name">{{ item.name }}</h3>
          <p class="practice__desc">
            {{ item.desc }}
          </p>
        </li>
        {% endfor %}</ol>

      <p class="practice__terms" data-reveal>
        {{ site.practice.terms }}
      </p>
    </section>

    <!-- ============ 03 PACKAGES ============ -->
    <section class="packages" id="packages" aria-labelledby="packages-title">
      <header class="chapter-head" data-reveal-head>
        <span class="chapter-head__num" aria-hidden="true">03</span>
        <h2 class="chapter-head__label" id="packages-title">{{ site.packages.chapterLabel }}</h2>
        <p class="chapter-head__note" data-reveal>
          {{ site.packages.chapterNote }}
        </p>
      </header>

      <p class="packages__lead" data-reveal-lines>
        {{ site.packages.lead | safe }}
      </p>

      <div class="pkg-tabs" role="tablist" aria-label="Package type" data-reveal>
        <button type="button" class="pkg-tab is-active" role="tab" id="pkg-tab-onetime" aria-selected="true" aria-controls="pkg-panel-onetime">One&#8209;time</button>
        <button type="button" class="pkg-tab" role="tab" id="pkg-tab-monthly" aria-selected="false" aria-controls="pkg-panel-monthly" tabindex="-1">Monthly</button>
        <button type="button" class="pkg-tab" role="tab" id="pkg-tab-staff" aria-selected="false" aria-controls="pkg-panel-staff" tabindex="-1">Staffing</button>
      </div>

      <div class="pkg-group is-active" id="pkg-panel-onetime" role="tabpanel" aria-labelledby="pkg-tab-onetime" tabindex="0">
        <p class="pkg-group__note">{{ site.packages.onetime.note }}</p>
        <div class="pkg-row">
          {% for card in site.packages.onetime.cards %}<article class="pkg{% if card.featured %} pkg--featured{% endif %}">
            {% if card.badge %}<p class="pkg__badge">{{ card.badge }}</p>
            {% endif %}<h4 class="pkg__name">{{ card.name }}</h4>
            <p class="pkg__price">{{ card.price }}{% if card.per %}<span class="pkg__per">{{ card.per }}</span>{% endif %}</p>
            <p class="pkg__desc">{{ card.desc }}</p>
            <a class="pkg__cta{% if card.featured %} pkg__cta--solid{% endif %}" href="{{ card.ctaUrl }}">{{ card.ctaLabel | safe }} <span aria-hidden="true">&rarr;</span></a>
            {% if card.more %}<p class="pkg__more">{{ card.more }}</p>
            {% endif %}<ul class="pkg__features">
              {% for feature in card.features %}<li>{{ feature | safe }}</li>
              {% endfor %}</ul>
          </article>
          {% endfor %}</div>
      </div>

      <div class="pkg-group" id="pkg-panel-monthly" role="tabpanel" aria-labelledby="pkg-tab-monthly" tabindex="0">
        <p class="pkg-group__note">{{ site.packages.monthly.note }}</p>
        <div class="pkg-row">
          {% for card in site.packages.monthly.cards %}<article class="pkg{% if card.featured %} pkg--featured{% endif %}">
            {% if card.badge %}<p class="pkg__badge">{{ card.badge }}</p>
            {% endif %}<h4 class="pkg__name">{{ card.name }}</h4>
            <p class="pkg__price">{{ card.price }}{% if card.per %}<span class="pkg__per">{{ card.per }}</span>{% endif %}</p>
            <p class="pkg__desc">{{ card.desc }}</p>
            <a class="pkg__cta{% if card.featured %} pkg__cta--solid{% endif %}" href="{{ card.ctaUrl }}">{{ card.ctaLabel | safe }} <span aria-hidden="true">&rarr;</span></a>
            {% if card.more %}<p class="pkg__more">{{ card.more }}</p>
            {% endif %}<ul class="pkg__features">
              {% for feature in card.features %}<li>{{ feature | safe }}</li>
              {% endfor %}</ul>
          </article>
          {% endfor %}</div>
      </div>

      <div class="pkg-group" id="pkg-panel-staff" role="tabpanel" aria-labelledby="pkg-tab-staff" tabindex="0">
        <p class="pkg-group__note">{{ site.packages.staff.note }}</p>
        <div class="pkg-row">
          {% for card in site.packages.staff.cards %}<article class="pkg{% if card.featured %} pkg--featured{% endif %}">
            {% if card.badge %}<p class="pkg__badge">{{ card.badge }}</p>
            {% endif %}<h4 class="pkg__name">{{ card.name }}</h4>
            <p class="pkg__price">{{ card.price }}{% if card.per %}<span class="pkg__per">{{ card.per }}</span>{% endif %}</p>
            <p class="pkg__desc">{{ card.desc }}</p>
            <a class="pkg__cta{% if card.featured %} pkg__cta--solid{% endif %}" href="{{ card.ctaUrl }}">{{ card.ctaLabel | safe }} <span aria-hidden="true">&rarr;</span></a>
            {% if card.more %}<p class="pkg__more">{{ card.more }}</p>
            {% endif %}<ul class="pkg__features">
              {% for feature in card.features %}<li>{{ feature | safe }}</li>
              {% endfor %}</ul>
          </article>
          {% endfor %}</div>
      </div>

      <p class="packages__guarantee" data-reveal>
        {{ site.packages.guarantee | safe }}
      </p>
    </section>

    <!-- ============ 04 EVIDENCE ============ -->
    <section class="evidence" id="evidence" aria-labelledby="evidence-title">
      <header class="chapter-head chapter-head--dark" data-reveal-head>
        <span class="chapter-head__num" aria-hidden="true">04</span>
        <h2 class="chapter-head__label" id="evidence-title">{{ site.evidence.chapterLabel }}</h2>
      </header>

      <p class="evidence__hold" data-reveal-lines>
        {{ site.evidence.hold | safe }}
      </p>
      <p class="evidence__note" data-reveal>
        {{ site.evidence.note }}
      </p>
      {%- if projectList.length %}
      <a class="evidence__link" href="/work/{{ projectList[0].slug | slugify }}/" data-reveal>
        {{ site.evidence.linkLabel }} <span aria-hidden="true">&rarr;</span>
      </a>
      {%- endif %}
    </section>

    <!-- ============ 05 STUDIO ============ -->
    <section class="studio" id="studio" aria-labelledby="studio-title">
      <header class="chapter-head" data-reveal-head>
        <span class="chapter-head__num" aria-hidden="true">05</span>
        <h2 class="chapter-head__label" id="studio-title">{{ site.studio.chapterLabel }}</h2>
      </header>

      <p class="studio__statement" data-reveal-lines>
        {{ site.studio.statement | safe }}
      </p>

      <ol class="principles">
        {% for item in site.studio.principles %}<li class="principles__item" data-reveal>
          <span class="principles__num" aria-hidden="true">{{ item.num }}</span>
          <p>{{ item.text }}</p>
        </li>
        {% endfor %}</ol>

      <p class="studio__where" data-reveal>
        {{ site.studio.where }}
      </p>
    </section>

    <!-- ============ 06 CONTACT ============ -->
    <section class="contact" id="contact" aria-labelledby="contact-title">
      <header class="chapter-head chapter-head--dark" data-reveal-head>
        <span class="chapter-head__num" aria-hidden="true">06</span>
        <h2 class="chapter-head__label" id="contact-title">{{ site.contact.chapterLabel }}</h2>
      </header>

      <p class="contact__statement" data-reveal-lines>
        {{ site.contact.statement | safe }}
      </p>

      <a class="contact__mail" href="mailto:{{ site.contact.email }}" data-magnetic>{{ site.contact.email }}</a>

      <p class="contact__note" data-reveal>
        {{ site.contact.note }}
      </p>
    </section>

    <!-- ============ SHOWREEL (optional full-bleed video band) ============ -->
    {%- set showreel = site.showreel -%}
    {% if showreel and showreel.video and showreel.video.src %}
    <section class="showreel" aria-label="{{ showreel.label | default('Showreel', true) }}">
      <figure class="showreel__media">{{ siteVideo(showreel.video, 'showreel__video') }}</figure>
      {% if showreel.label %}<p class="showreel__label">{{ showreel.label | safe }}</p>{% endif %}
    </section>
    {% endif %}
  </main>

  <footer class="site-foot">
    <div class="site-foot__grid">
      <nav class="site-foot__col" aria-label="Footer">
        <h2 class="site-foot__label">{{ site.footer.indexLabel }}</h2>
        {% for link in site.footer.indexLinks %}<a href="{{ link.href }}">{{ link.label }}</a>
        {% endfor %}</nav>
      <div class="site-foot__col">
        <h2 class="site-foot__label">{{ site.footer.elsewhereLabel }}</h2>
        {% for link in site.footer.socialLinks %}<a href="{{ link.url }}" rel="noopener">{{ link.label }}</a>
        {% endfor %}</div>
      <div class="site-foot__col site-foot__col--ai">
        <h2 class="site-foot__label">{{ site.footer.askAiLabel }}</h2>
        <ul class="ai-row">
          <li><a class="ai-chip" href="https://chatgpt.com/?q={{ site.footer.askAiPrompt | urlencode }}" target="_blank" rel="noopener noreferrer" aria-label="Ask ChatGPT to summarise OOVERT"><img src="/assets/ai/openai.svg" alt="" width="20" height="20" loading="lazy"></a></li>
          <li><a class="ai-chip" href="https://claude.ai/new?q={{ site.footer.askAiPrompt | urlencode }}" target="_blank" rel="noopener noreferrer" aria-label="Ask Claude to summarise OOVERT"><img src="/assets/ai/claude.svg" alt="" width="20" height="20" loading="lazy"></a></li>
          <li><a class="ai-chip" href="https://www.perplexity.ai/search?q={{ site.footer.askAiPrompt | urlencode }}" target="_blank" rel="noopener noreferrer" aria-label="Ask Perplexity to summarise OOVERT"><img src="/assets/ai/perplexity.svg" alt="" width="20" height="20" loading="lazy"></a></li>
          <li><a class="ai-chip" href="https://gemini.google.com/app?q={{ site.footer.askAiPrompt | urlencode }}" target="_blank" rel="noopener noreferrer" aria-label="Ask Google Gemini to summarise OOVERT"><img src="/assets/ai/googlegemini.svg" alt="" width="20" height="20" loading="lazy"></a></li>
        </ul>
      </div>
    </div>
    <p class="site-foot__mark" aria-hidden="true">
      <svg viewBox="0 0 297.55 66.38" fill="currentColor">
