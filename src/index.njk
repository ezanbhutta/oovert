{#- siteVideo(v, cls) — a homepage <video> with its owner settings. Autoplay
    implies muted + playsinline; speed / start / end are read by the video.js
    module as data-rate / start / end. -#}
{%- macro siteVideo(v, cls='') -%}
<video class="cs-video{% if cls %} {{ cls }}{% endif %}"{% if v.poster %} poster="{{ v.poster }}"{% endif %}{% if v.controls %} controls{% endif %}{% if v.loop %} loop{% endif %}{% if v.autoplay %} autoplay muted playsinline{% elif v.muted %} muted{% endif %} preload="metadata" data-cs-video{% if v.speed %} data-rate="{{ v.speed }}"{% endif %}{% if v.start %} data-start="{{ v.start }}"{% endif %}{% if v.end %} data-end="{{ v.end }}"{% endif %}><source src="{{ v.src }}"></video>
{%- endmacro -%}
<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
  <meta charset="UTF-8">
  {% include "analytics.njk" %}
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ site.meta.pageTitle }}</title>
  <meta name="description" content="{{ site.meta.description }}">
  <link rel="canonical" href="{{ site.meta.canonicalUrl }}">
  <meta name="theme-color" content="{{ site.meta.themeColor }}">

  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.meta.og.siteName }}">
  <meta property="og:title" content="{{ site.meta.og.title }}">
  <meta property="og:description" content="{{ site.meta.og.description }}">
  <meta property="og:url" content="{{ site.meta.og.url }}">
  <meta property="og:image" content="{{ site.meta.og.image }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{ site.meta.og.imageAlt }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ site.meta.twitter.title }}">
  <meta name="twitter:description" content="{{ site.meta.twitter.description }}">
  <meta name="twitter:image" content="{{ site.meta.twitter.image }}">

  <link rel="icon" href="favicon.svg" type="image/svg+xml">
  <link rel="icon" href="favicon.ico" sizes="32x32">
  <link rel="apple-touch-icon" href="apple-touch-icon.png">

  <script>
    document.documentElement.classList.replace('no-js', 'js');
    // Entrance gate: masked serif reveals must never FOUT mid-rise. Failsafe
    // releases the gate at 600ms even if the fonts promise stalls.
    document.fonts.ready.then(function () { document.documentElement.classList.add('fonts-ready'); });
    setTimeout(function () { document.documentElement.classList.add('fonts-ready'); }, 600);
    // First visit gets the overture; returns get the same move, compressed.
    try {
      if (sessionStorage.getItem('ov-entered')) document.documentElement.classList.add('is-return');
      else sessionStorage.setItem('ov-entered', '1');
    } catch (e) {}
  </script>

  <link rel="preload" href="assets/fonts/archivo-var.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="assets/fonts/instrument-serif-italic.woff2" as="font" type="font/woff2" crossorigin>

  <link rel="stylesheet" href="css/foundation.css">
  <link rel="stylesheet" href="css/components.css">
  <link rel="stylesheet" href="css/sections.css">

  <link rel="modulepreload" href="js/modules/reveal.js">
  <link rel="modulepreload" href="js/modules/nav.js">
  <link rel="modulepreload" href="js/modules/parallax.js">
  <link rel="modulepreload" href="js/modules/counters.js">
  <link rel="modulepreload" href="js/modules/smooth-scroll.js">
  <link rel="modulepreload" href="js/modules/manifesto.js">
  <link rel="modulepreload" href="js/modules/backdrop.js">
  <link rel="modulepreload" href="js/modules/herofield.js">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "additionalType": "https://schema.org/ProfessionalService",
    "name": {{ site.schema.name | dump | safe }},
    "legalName": {{ site.schema.legalName | dump | safe }},
    "url": {{ site.schema.url | dump | safe }},
    "email": {{ site.schema.email | dump | safe }},
    "foundingDate": {{ site.schema.foundingDate | dump | safe }},
    "slogan": {{ site.schema.slogan | dump | safe }},
    "description": {{ site.schema.description | dump | safe }},
    "logo": {{ site.schema.logo | dump | safe }},
    "image": {{ site.schema.image | dump | safe }},
    "areaServed": {{ site.schema.areaServed | dump | safe }},
    "knowsAbout": {{ site.schema.knowsAbout | dump | safe }},
    "makesOffer": [
{% for offer in site.schema.makesOffer %}      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": {{ offer | dump | safe }} } }{% if not loop.last %},{% endif %}
{% endfor %}    ]{% if site.schema.sameAs and site.schema.sameAs.length %},
    "sameAs": {{ site.schema.sameAs | dump | safe }}{% endif %}
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
{% for item in site.faq.items %}      {
        "@type": "Question",
        "name": {{ item.q | dump | safe }},
        "acceptedAnswer": { "@type": "Answer", "text": {{ item.a | dump | safe }} }
      }{% if not loop.last %},{% endif %}
{% endfor %}    ]
  }
  </script>
</head>
<body>
  <a class="skip-link" href="#main">{{ site.a11y.skipLink }}</a>

  <header class="site-head">
    <a class="site-head__mark" href="#top" aria-label="OOVERT, back to top">
      {% include "mark.njk" %}
    </a>
    <nav class="site-head__nav" aria-label="Primary">
      {% for link in site.nav.links %}<a href="{{ link.href }}">{{ link.label }}</a>
      {% endfor %}</nav>
    <button class="site-head__menu" type="button" aria-expanded="false" aria-controls="menu-overlay" aria-label="Menu">
      <span class="site-head__menu-label" aria-hidden="true"><span>{{ site.nav.menuButtonLabel }}</span><span>Close</span></span>
    </button>
  </header>

  <div class="menu-overlay" id="menu-overlay" role="dialog" aria-modal="true" aria-label="Menu" hidden>
    <nav class="menu-overlay__nav" aria-label="Menu">
      {% for link in site.menu.links %}<a href="{{ link.href }}"><span class="menu-overlay__num">{{ link.num }}</span>{{ link.label }}</a>
      {% endfor %}</nav>
    <p class="menu-overlay__meta">{{ site.menu.meta | safe }}</p>
  </div>

  <nav class="chapter-rail" aria-label="Chapters">
    {% for item in site.chapterRail %}<a href="{{ item.href }}" aria-label="{{ item.aria }}"><span>{{ item.num }}</span></a>
    {% endfor %}</nav>

  <main id="main">

    <!-- ============ HERO ============ -->
    {%- set heroVideo = site.hero.video -%}
    <section class="hero{% if heroVideo and heroVideo.src %} hero--video{% endif %}" id="top" aria-label="Introduction">
      {% if heroVideo and heroVideo.src %}
      {{ siteVideo(heroVideo, 'hero__video') }}
      <div class="hero__scrim" aria-hidden="true"></div>
      {% else %}
      <canvas class="hero__bg" aria-hidden="true"></canvas>
      {% endif %}
      {#- Entrance cadence: tight pair for the headline (.12/.24), a breath
          while it settles alone, then a widening tail (.64/.76/.90/1.06) —
          shaped, not metronomic. Meta tags step in 70ms apart. -#}
      <div class="hero__meta">
        {% for tag in site.hero.metaTags %}<span data-entrance style="--d:{{ (0.64 + loop.index0 * 0.07) | round(2) }}s">{{ tag }}</span>
        {% endfor %}</div>

      <h1 class="hero__title">
        {{ site.hero.title | safe }}
      </h1>

      <div class="hero__foot">
        <p class="hero__lede" data-entrance style="--d:.76s">
          {{ site.hero.lede }}
        </p>
        <div class="hero__cta" data-entrance style="--d:.90s">
          <a class="btn" href="{{ site.hero.ctaPrimary.url }}" data-magnetic><span class="btn__label">{{ site.hero.ctaPrimary.label }}</span><span class="btn__arrow" aria-hidden="true">&darr;</span></a>
          <a class="link-quiet" href="{{ site.hero.ctaSecondary.url }}">{{ site.hero.ctaSecondary.label }}</a>
        </div>
      </div>

      <div class="hero__strip" data-entrance style="--d:1.06s">
        <span class="hero__scroll" aria-hidden="true">{{ site.hero.scrollLabel }}<i></i></span>
        <span>{{ site.hero.statusLine }}</span>
      </div>
    </section>

    <!-- ============ 01 PREMISE ============ -->
    <section class="premise" id="premise" aria-labelledby="premise-title">
      <header class="chapter-head" data-reveal-head>
        <span class="chapter-head__num" aria-hidden="true">01</span>
        <h2 class="chapter-head__label" id="premise-title">{{ site.premise.chapterLabel }}</h2>
      </header>

      <p class="premise__statement" data-reveal-lines>
        {{ site.premise.statement | safe }}
      </p>

      <div class="premise__body" data-reveal>
        <p>
          {{ site.premise.body }}
        </p>
      </div>

      <p class="premise__counter" data-reveal-lines>
        {{ site.premise.counter | safe }}
      </p>

      <div class="premise__pull" data-reveal>
        <p class="premise__pull-line">{{ site.premise.pullLine | safe }}</p>
        <p class="premise__pull-note">
          {{ site.premise.pullNote }}
        </p>
      </div>
    </section>

    <!-- ============ MANIFESTO ============ -->
    <section class="manifesto" aria-label="What we do">
      <div class="manifesto__stage">
      <canvas class="manifesto__bg" aria-hidden="true"></canvas>
      <p class="manifesto__text" data-manifesto>{{ site.manifesto.text | safe }}</p>
      </div>
    </section>

    <!-- ============ 02 PRACTICE ============ -->
    <section class="practice" id="practice" aria-labelledby="practice-title">
      <header class="chapter-head chapter-head--dark" data-reveal-head>
        <span class="chapter-head__num" aria-hidden="true">02</span>
        <h2 class="chapter-head__label" id="practice-title">{{ site.practice.chapterLabel }}</h2>
      </header>

      <p class="practice__intro" data-reveal-lines>
        {{ site.practice.intro | safe }}
      </p>

      <div class="wwd" data-wwd data-reveal>
        <ul class="wwd__names" role="tablist" aria-label="What we do">
          {% for item in site.practice.items %}<li class="wwd__item" role="presentation">
            <button type="button" class="wwd__trigger{% if loop.first %} is-active{% endif %}" role="tab" id="wwd-tab-{{ loop.index0 }}" aria-selected="{{ 'true' if loop.first else 'false' }}" aria-controls="wwd-panel-{{ loop.index0 }}" data-wwd-i="{{ loop.index0 }}"{% if not loop.first %} tabindex="-1"{% endif %}>
              <span class="wwd__num" aria-hidden="true">{{ item.num }}</span>
              <span class="wwd__name">{{ item.name }}</span>
            </button>
          </li>
          {% endfor %}</ul>
        <div class="wwd__stage">
          <span class="wwd__eclipse" aria-hidden="true">
            <svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="1.25">
              <circle cx="52" cy="60" r="40"/>
              <circle cx="68" cy="60" r="40"/>
            </svg>
          </span>
          {% for item in site.practice.items %}<div class="wwd__panel{% if loop.first %} is-active{% endif %}" role="tabpanel" id="wwd-panel-{{ loop.index0 }}" aria-labelledby="wwd-tab-{{ loop.index0 }}"{% if not loop.first %} hidden{% endif %}>
            <p class="wwd__desc">{{ item.desc }}</p>
          </div>
          {% endfor %}</div>
      </div>

      <p class="practice__terms" data-reveal>
        {{ site.practice.terms }}
      </p>
    </section>

    <!-- ============ 03 PACKAGES ============ -->
    <section class="packages" id="packages" aria-labelledby="packages-title">
      <header class="chapter-head" data-reveal-head>
        <span class="chapter-head__num" aria-hidden="true">03</span>
        <h2 class="chapter-head__label" id="packages-title">{{ site.packages.chapterLabel }}</h2>
        <p class="chapter-head__note" data-reveal>
          {{ site.packages.chapterNote }}
        </p>
      </header>

      <p class="packages__lead" data-reveal-lines>
        {{ site.packages.lead | safe }}
      </p>

      <div class="pkg-tabs" role="tablist" aria-label="Package type" data-reveal>
        <button type="button" class="pkg-tab is-active" role="tab" id="pkg-tab-onetime" aria-selected="true" aria-controls="pkg-panel-onetime">One&#8209;time</button>
        <button type="button" class="pkg-tab" role="tab" id="pkg-tab-monthly" aria-selected="false" aria-controls="pkg-panel-monthly" tabindex="-1">Monthly</button>
        <button type="button" class="pkg-tab" role="tab" id="pkg-tab-staff" aria-selected="false" aria-controls="pkg-panel-staff" tabindex="-1">Staffing</button>
      </div>

      <div class="pkg-group is-active" id="pkg-panel-onetime" role="tabpanel" aria-labelledby="pkg-tab-onetime" tabindex="0">
        <p class="pkg-group__note">{{ site.packages.onetime.note }}</p>
        <div class="ledger">
          {% for card in site.packages.onetime.cards %}<article class="ledger-row{% if card.featured %} is-featured is-open{% endif %}">
            <button type="button" class="ledger-row__head" aria-expanded="{{ 'true' if card.featured else 'false' }}" aria-controls="ledger-onetime-{{ loop.index }}">
              <span class="ledger-row__num" aria-hidden="true">0{{ loop.index }}</span>
              <span class="ledger-row__id">
                <span class="ledger-row__name-line">
                  <span class="ledger-row__name">{{ card.name }}</span>
                  {% if card.badge %}<span class="ledger-row__tag"><span class="ledger-row__tag-mark" aria-hidden="true">&#10022;</span>{{ card.badge }}</span>{% endif %}
                </span>
                <span class="ledger-row__desc">{{ card.desc }}</span>
              </span>
              <span class="ledger-row__price">{{ card.price }}{% if card.per %}<span class="ledger-row__per">{{ card.per }}</span>{% endif %}</span>
              <span class="ledger-row__toggle" aria-hidden="true"></span>
            </button>
            <div class="ledger-row__panel" id="ledger-onetime-{{ loop.index }}">
              <div class="ledger-row__panel-inner">
                <div class="ledger-row__panel-body">
                  {% if card.more %}<p class="ledger-row__more">{{ card.more }}</p>{% endif %}
                  <ul class="ledger-row__features">
                    {% for feature in card.features %}<li>{{ feature | safe }}</li>{% endfor %}
                  </ul>
                  <a class="ledger-row__cta{% if card.featured %} ledger-row__cta--solid{% endif %}" href="{{ card.ctaUrl }}">{{ card.ctaLabel | safe }} <span aria-hidden="true">&rarr;</span></a>
                </div>
              </div>
            </div>
          </article>
          {% endfor %}</div>
      </div>

      <div class="pkg-group" id="pkg-panel-monthly" role="tabpanel" aria-labelledby="pkg-tab-monthly" tabindex="0">
        <p class="pkg-group__note">{{ site.packages.monthly.note }}</p>
        <div class="ledger">
          {% for card in site.packages.monthly.cards %}<article class="ledger-row{% if card.featured %} is-featured is-open{% endif %}">
            <button type="button" class="ledger-row__head" aria-expanded="{{ 'true' if card.featured else 'false' }}" aria-controls="ledger-monthly-{{ loop.index }}">
              <span class="ledger-row__num" aria-hidden="true">0{{ loop.index }}</span>
              <span class="ledger-row__id">
                <span class="ledger-row__name-line">
                  <span class="ledger-row__name">{{ card.name }}</span>
                  {% if card.badge %}<span class="ledger-row__tag"><span class="ledger-row__tag-mark" aria-hidden="true">&#10022;</span>{{ card.badge }}</span>{% endif %}
                </span>
                <span class="ledger-row__desc">{{ card.desc }}</span>
              </span>
              <span class="ledger-row__price">{{ card.price }}{% if card.per %}<span class="ledger-row__per">{{ card.per }}</span>{% endif %}</span>
              <span class="ledger-row__toggle" aria-hidden="true"></span>
            </button>
            <div class="ledger-row__panel" id="ledger-monthly-{{ loop.index }}">
              <div class="ledger-row__panel-inner">
                <div class="ledger-row__panel-body">
                  {% if card.more %}<p class="ledger-row__more">{{ card.more }}</p>{% endif %}
                  <ul class="ledger-row__features">
                    {% for feature in card.features %}<li>{{ feature | safe }}</li>{% endfor %}
                  </ul>
                  <a class="ledger-row__cta{% if card.featured %} ledger-row__cta--solid{% endif %}" href="{{ card.ctaUrl }}">{{ card.ctaLabel | safe }} <span aria-hidden="true">&rarr;</span></a>
                </div>
              </div>
            </div>
          </article>
          {% endfor %}</div>
      </div>

      <div class="pkg-group" id="pkg-panel-staff" role="tabpanel" aria-labelledby="pkg-tab-staff" tabindex="0">
        <p class="pkg-group__note">{{ site.packages.staff.note }}</p>
        <div class="ledger">
          {% for card in site.packages.staff.cards %}<article class="ledger-row{% if card.featured %} is-featured is-open{% endif %}">
            <button type="button" class="ledger-row__head" aria-expanded="{{ 'true' if card.featured else 'false' }}" aria-controls="ledger-staff-{{ loop.index }}">
              <span class="ledger-row__num" aria-hidden="true">0{{ loop.index }}</span>
              <span class="ledger-row__id">
                <span class="ledger-row__name-line">
                  <span class="ledger-row__name">{{ card.name }}</span>
                  {% if card.badge %}<span class="ledger-row__tag"><span class="ledger-row__tag-mark" aria-hidden="true">&#10022;</span>{{ card.badge }}</span>{% endif %}
                </span>
                <span class="ledger-row__desc">{{ card.desc }}</span>
              </span>
              <span class="ledger-row__price">{{ card.price }}{% if card.per %}<span class="ledger-row__per">{{ card.per }}</span>{% endif %}</span>
              <span class="ledger-row__toggle" aria-hidden="true"></span>
            </button>
            <div class="ledger-row__panel" id="ledger-staff-{{ loop.index }}">
              <div class="ledger-row__panel-inner">
                <div class="ledger-row__panel-body">
                  {% if card.more %}<p class="ledger-row__more">{{ card.more }}</p>{% endif %}
                  <ul class="ledger-row__features">
                    {% for feature in card.features %}<li>{{ feature | safe }}</li>{% endfor %}
                  </ul>
                  <a class="ledger-row__cta{% if card.featured %} ledger-row__cta--solid{% endif %}" href="{{ card.ctaUrl }}">{{ card.ctaLabel | safe }} <span aria-hidden="true">&rarr;</span></a>
                </div>
              </div>
            </div>
          </article>
          {% endfor %}</div>
      </div>

      <p class="packages__guarantee" data-reveal>
        {{ site.packages.guarantee | safe }}
      </p>
    </section>

    <!-- ============ 04 EVIDENCE ============ -->
    <section class="evidence" id="evidence" aria-labelledby="evidence-title">
      <header class="chapter-head chapter-head--dark" data-reveal-head>
        <span class="chapter-head__num" aria-hidden="true">04</span>
        <h2 class="chapter-head__label" id="evidence-title">{{ site.evidence.chapterLabel }}</h2>
      </header>

      <p class="evidence__hold" data-reveal-lines>
        {{ site.evidence.hold | safe }}
      </p>
      <p class="evidence__note" data-reveal>
        {{ site.evidence.note }}
      </p>
      <a class="evidence__link" href="/work/" data-reveal>
        {{ site.evidence.linkLabel }} <span aria-hidden="true">&rarr;</span>
      </a>
    </section>

    <!-- ============ 05 STUDIO ============ -->
    <section class="studio" id="studio" aria-labelledby="studio-title">
      <header class="chapter-head" data-reveal-head>
        <span class="chapter-head__num" aria-hidden="true">05</span>
        <h2 class="chapter-head__label" id="studio-title">{{ site.studio.chapterLabel }}</h2>
      </header>

      <p class="studio__statement" data-reveal-lines>
        {{ site.studio.statement | safe }}
      </p>

      <ol class="principles">
        {% for item in site.studio.principles %}<li class="principles__item" data-reveal>
          <span class="principles__num" aria-hidden="true">{{ item.num }}</span>
          <p>{{ item.text }}</p>
        </li>
        {% endfor %}</ol>

      <p class="studio__where" data-reveal>
        {{ site.studio.where }}
      </p>
    </section>

    <!-- ============ 06 QUESTIONS (FAQ) ============ -->
    <section class="faq-section" id="faq" aria-labelledby="faq-title">
      <header class="chapter-head" data-reveal-head>
        <span class="chapter-head__num" aria-hidden="true">06</span>
        <h2 class="chapter-head__label" id="faq-title">{{ site.faq.chapterLabel }}</h2>
      </header>

      <p class="faq-statement" data-reveal-lines>
        {{ site.faq.statement | safe }}
      </p>

      <div class="faq">
        {% for item in site.faq.items %}<details class="faq__item"{% if loop.first %} open{% endif %}>
          <summary class="faq__q">
            <span class="faq__q-text">{{ item.q }}</span>
            <span class="faq__marker" aria-hidden="true"></span>
          </summary>
          <div class="faq__a"><p>{{ item.a }}</p></div>
        </details>
        {% endfor %}</div>
    </section>

    <!-- ============ 07 CONTACT ============ -->
    <section class="contact" id="contact" aria-labelledby="contact-title">
      <header class="chapter-head chapter-head--dark" data-reveal-head>
        <span class="chapter-head__num" aria-hidden="true">07</span>
        <h2 class="chapter-head__label" id="contact-title">{{ site.contact.chapterLabel }}</h2>
      </header>

      <p class="contact__statement" data-reveal-lines>
        {{ site.contact.statement | safe }}
      </p>

      <a class="contact__mail" href="mailto:{{ site.contact.email }}" data-magnetic>{{ site.contact.email }}</a>

      <p class="contact__note" data-reveal>
        {{ site.contact.note }}
      </p>
    </section>

    <!-- ============ SHOWREEL (optional full-bleed video band) ============ -->
    {%- set showreel = site.showreel -%}
    {% if showreel and showreel.video and showreel.video.src %}
    <section class="showreel" aria-label="{{ showreel.label | default('Showreel', true) }}">
      <figure class="showreel__media">{{ siteVideo(showreel.video, 'showreel__video') }}</figure>
      {% if showreel.label %}<p class="showreel__label">{{ showreel.label | safe }}</p>{% endif %}
    </section>
    {% endif %}
  </main>

  <footer class="site-foot">
    <div class="site-foot__grid">
      <nav class="site-foot__col" aria-label="Footer">
        <h2 class="site-foot__label">{{ site.footer.indexLabel }}</h2>
        {% for link in site.footer.indexLinks %}<a href="{{ link.href }}">{{ link.label }}</a>
        {% endfor %}</nav>
      <div class="site-foot__col">
        <h2 class="site-foot__label">{{ site.footer.elsewhereLabel }}</h2>
        {% for link in site.footer.socialLinks %}<a href="{{ link.url }}" rel="noopener">{{ link.label }}</a>
        {% endfor %}</div>
      <div class="site-foot__col site-foot__col--ai">
        <h2 class="site-foot__label">{{ site.footer.askAiLabel }}</h2>
        <ul class="ai-row">
