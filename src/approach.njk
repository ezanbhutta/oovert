---
permalink: "/approach/index.html"
---
{%- set currentPath = "/approach/" -%}
<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Approach — OOVERT</title>
  <meta name="description" content="How OOVERT works: a brand built in four moves — Strategy, Positioning, Identity, Rollout — each one finished before the next begins, and exactly what you leave with.">
  <link rel="canonical" href="https://oovert.com/approach/">
  <meta name="theme-color" content="#F3F0E9">

  <meta property="og:type" content="website">
  <meta property="og:site_name" content="OOVERT">
  <meta property="og:title" content="Approach — OOVERT">
  <meta property="og:description" content="A brand built in four moves. Strategy, Positioning, Identity, Rollout — and exactly what you leave with.">
  <meta property="og:url" content="https://oovert.com/approach/">
  <meta property="og:image" content="https://oovert.com/assets/og.png">
  <meta name="twitter:card" content="summary_large_image">

  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <script>document.documentElement.classList.replace('no-js', 'js');</script>

  <link rel="preload" href="/assets/fonts/archivo-var.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/instrument-serif-italic.woff2" as="font" type="font/woff2" crossorigin>

  <link rel="stylesheet" href="/css/foundation.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/sections.css">
  <link rel="stylesheet" href="/css/work.css">

  <link rel="modulepreload" href="/js/modules/reveal.js">
  <link rel="modulepreload" href="/js/modules/nav.js">
</head>
<body class="page-approach">
  <a class="skip-link" href="#main">{{ site.a11y.skipLink }}</a>

  {% include "site-header.njk" %}

  <main id="main" class="approach">
    <header class="work-hero" id="top">
      <p class="work-hero__eyebrow" data-reveal>{{ approach.eyebrow }}</p>
      <h1 class="work-hero__title" data-reveal-lines>
        <span class="line"><span class="line__inner">One direction.</span></span>
        <span class="line"><span class="line__inner"><em>Four moves.</em></span></span>
      </h1>
      <p class="work-hero__lede" data-reveal>{{ approach.lede }}</p>
    </header>

    <ol class="approach-spine">
      {% for phase in approach.phases %}
      <li class="phase" data-reveal>
        <div class="phase__marker">
          <span class="phase__num" aria-hidden="true">{{ phase.num }}</span>
          <span class="phase__role">{{ phase.role }}</span>
          <h2 class="phase__name">{{ phase.name }}</h2>
        </div>
        <div class="phase__body">
          <p class="phase__summary">{{ phase.summary }}</p>
          <div class="phase__deliverables">
            <p class="phase__deliverables-label">You leave with</p>
            <ul>
              {% for d in phase.deliverables %}<li>{{ d }}</li>
              {% endfor %}</ul>
          </div>
        </div>
      </li>
      {% endfor %}
    </ol>

    <section class="work-more">
      <p class="work-more__line" data-reveal-lines>
        <span class="line"><span class="line__inner">{{ approach.closing.line | safe }}</span></span>
      </p>
      <p class="work-more__note" data-reveal>{{ approach.closing.note }}</p>
      <a class="work-more__cta" href="{{ approach.closing.ctaUrl }}" data-reveal>{{ approach.closing.ctaLabel }} <span aria-hidden="true">&rarr;</span></a>
    </section>
  </main>

  {% include "site-footer.njk" %}

  <script type="module" src="/js/work.js"></script>
</body>
</html>
